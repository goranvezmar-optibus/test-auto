{
  "name": "ride-ui",
  "version": "1.0.7",
  "type": "module",
  "description": "Optibus UI component library.",
  "author": "Dan Fishgold dan.fishgold@optibus.com",
  "license": "© 2026 Optibus. All Rights Reserved.",
  "homepage": "https://github.com/Optibus/ride-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Optibus/ride-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Optibus/ride-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:watch": "tsc --noEmit && vite build --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/types/ride-ui.d.ts",
      "import": "./dist/ride-ui.js",
      "require": "./dist/ride-ui.umd.cjs"
    },
    "./css": {
      "types": "./dist/types/ride-ui.d.ts",
      "import": "./dist/ride-ui.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "registry": "https://fury.io"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@auto-it/git-tag": "^11.3.6",
    "@auto-it/npm": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "auto": "^11.3.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.4",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
